---
import { SEO } from 'astro-seo';

interface Props {
    title?: string;
    description?: string;
    ogImage?: string;
}
const {
    title,
    description = 'I post about my thoughts on life, engineering, philosophy, basicly everything. (Of course don\'t  forget AI too)',
    ogImage = 'https://hhyurdagul.com/og.png',
} = Astro.props as Props;
const twitterHandle = '@hhyurdagul';
---

<SEO
    title={title ? `${title} | HHYurdagul` : 'HHYurdagul'}
    description={description}
    openGraph={{
        basic: {
            title: 'HHYurdagul',
            type: 'website',
            image: ogImage,
        },
    }}
    twitter={{
        creator: twitterHandle,
        card: 'summary_large_image',
        site: twitterHandle,
        title: 'hhyurdagul',
        description,
        image: ogImage,
        imageAlt: 'hhyurdagul',
    }}
    extend={{
        link: [
            {
                rel: 'sitemap',
                href: '/sitemap-index.xml',
            },
        ],
        meta: [
            {
                name: 'google-site-verification',
                // content: '2PrS27IRbrLgYfKmOC1bjuPohSqqsGbEUVY6dKD0bic',
            },
            {
                name: 'yandex-verification',
                // content: 'd1860867354dc963',
            },
        ],
    }}
/>
