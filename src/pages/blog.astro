---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import Card from "../components/Card.astro";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Blog" description="All blog posts from Hasan Hüseyin Yurdagül">
  <div class="container">
    <div class="main-layout">
      <Navigation />

      <main class="content">
        <section id="blog" aria-labelledby="blog-heading">
          <h2 id="blog-heading">All Posts</h2>
          {
            allPosts.map((post) => (
              <Card
                title={post.data.title}
                href={`/blog/${post.id}`}
                dateymd={post.data.pubDate.toISOString().split("T")[0]}
                datemyd={post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "2-digit",
                })}
              >
                {post.data.description}
              </Card>
            ))
          }
        </section>

        <Footer />
      </main>
    </div>
  </div>
</Layout>

<style>
  .container {
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 6rem 2rem;
  }

  .main-layout {
    display: flex;
    gap: 4rem;
  }

  .content {
    width: 70%;
    min-width: 0;
    animation: fadeInContent 1s ease-in-out forwards;
  }

  @keyframes fadeInContent {
    from {
      opacity: 0;
      transform: translateY(30px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 820px) {
    .main-layout {
      flex-direction: column;
      gap: 0;
    }

    .content {
      width: 100%;
    }
  }
</style>
